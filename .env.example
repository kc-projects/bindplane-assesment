# Bindplane Assessment - Variables de entorno
# Copiá este archivo como .env y completá los valores:
#   cp .env.example .env

# API Key de Bindplane (obligatorio)
# Obtenerla en: Bindplane → Settings → API Keys
BINDPLANE_API_KEY=InsertApiKey
# 

# URL de la instancia (opcional)
# - Cloud (default): https://app.bindplane.com
# - Self-hosted: https://tu-instancia.bindplane.com
BINDPLANE_URL=https://app.bindplane.com
